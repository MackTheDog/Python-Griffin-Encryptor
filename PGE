        self.strength_label.pack(side="left", padx=(5, 0))
        
        tk.Label(self.main_frame, text="Security Level:", bg="#f0f0f0", font=("Helvetica", 10, "bold")).pack(anchor="w")
        self.security_level = ttk.Combobox(self.main_frame, values=["Fast", "Normal", "Paranoid"], state="readonly")
        self.security_level.set("Normal")
        self.security_level.pack(fill="x", pady=(0, 15))
        
        tk.Label(self.main_frame, text="Package Contents:", bg="#f0f0f0", font=("Helvetica", 10, "bold")).pack(anchor="w")
        self.text_input = tk.Text(self.main_frame, height=8, relief="solid", borderwidth=1, font=("Helvetica", 9), bg="white")
        self.text_input.pack(expand=True, fill="both", pady=(0, 15))
        self.text_input.drop_target_register(DND_FILES)
        self.text_input.dnd_bind('<<Drop>>', self.handle_drop)
        self.text_input.insert("1.0", "Drag and drop files or folders here...")
        self.text_input.config(state="disabled")
        
        self.progress_label = tk.Label(self.main_frame, text="Status: Ready", bg="#f0f0f0", anchor="w")
        self.progress_label.pack(fill="x")
        self.progress_bar = ttk.Progressbar(self.main_frame, orient="horizontal", length=100, mode="determinate")
        self.progress_bar.pack(fill="x", pady=(0, 15))
        
        button_container = tk.Frame(self.main_frame, bg="#f0f0f0")
        button_container.pack(fill="x")
        self.mode_var = tk.StringVar(value="Encrypt")
        encrypt_button = tk.Radiobutton(button_container, text="Encrypt", variable=self.mode_var, value="Encrypt", command=self.update_ui_for_mode, bg="#f0f0f0", indicatoron=0, width=10, relief="raised", selectcolor="#c8e6c9")
        encrypt_button.pack(side="left")
        decrypt_button = tk.Radiobutton(button_container, text="Decrypt", variable=self.mode_var, value="Decrypt", command=self.update_ui_for_mode, bg="#f0f0f0", indicatoron=0, width=10, relief="raised", selectcolor="#ffcdd2")
        decrypt_button.pack(side="left", padx=5)
        
        self.process_button = tk.Button(button_container, text="Process", command=self.process, font=("Helvetica", 10, "bold"), bg="#4CAF50", fg="white")
        self.process_button.pack(side="right")
        self.clear_button = tk.Button(button_container, text="Clear", command=self.clear_fields)
        self.clear_button.pack(side="right", padx=5)
        
        self._update_password_strength()
        self.check_queue()

    def _update_password_strength(self, event=None):
        password, score = self.password_entry.get(), 0
        if len(password) >= 8: score += 1
        if len(password) >= 12: score += 1
        if re.search(r"[a-z]", password): score += 1
        if re.search(r"[A-Z]", password): score += 1
        if re.search(r"[0-9]", password): score += 1
        if re.search(r"[\W_]", password): score += 1
        colors = {0: ("#f0f0f0", "Too short"), 1: ("#ff4d4d", "Very Weak"), 2: ("#ff8c4d", "Weak"), 3: ("#ffd24d", "Medium"), 4: ("#86e06c", "Good"), 5: ("#33cc33", "Strong"), 6: ("#009933", "Very Strong")}
        color, text = colors.get(score, colors[0])
        self.strength_bar['value'] = (score / 6) * 100
        self.strength_label.config(text=text)
        style_name = f"Strength.{text.replace(' ', '')}.Horizontal.TProgressbar"
        ttk.Style().configure(style_name, background=color)
        self.strength_bar.config(style=style_name)

    def check_queue(self):
        try:
            while True:
                message = self.progress_queue.get_nowait()
                if isinstance(message, tuple) and len(message) == 2:
                    processed, total = message
                    percent = (processed / total) * 100 if total > 0 else 0
                    self.progress_bar['value'] = percent
                    self.progress_label.config(text=f"Processing... {int(percent)}%")
                elif isinstance(message, str):
                    self.progress_label.config(text=message)
        except queue.Empty:
            pass
        finally:
            self.root.after(100, self.check_queue)
            
    def handle_drop(self, event):
        try:
            newly_dropped_paths = [p for p in self.root.tk.splitlist(event.data) if p.strip() and os.path.exists(p.strip())]
            if not newly_dropped_paths:
                return
            is_decrypt_file = len(newly_dropped_paths) == 1 and newly_dropped_paths[0].endswith('.grn')
            if is_decrypt_file:
                self.input_paths = newly_dropped_paths
                self.mode_var.set("Decrypt")
            else:
                for p in newly_dropped_paths:
                    if p not in self.input_paths:
                        self.input_paths.append(p)
                self.mode_var.set("Encrypt")
            self.update_display_text()
        except Exception as e:
            messagebox.showerror("Drop Error", f"Could not process dropped items: {e}")
            self.clear_fields()

    def update_display_text(self):
        self.text_input.config(state="normal")
        self.text_input.delete("1.0", tk.END)
        if not self.input_paths:
            display_text = "Drag and drop files or folders here..."
        elif self.mode_var.get() == "Decrypt":
            display_text = f"Ready to decrypt archive:\n\n- {os.path.basename(self.input_paths[0])}"
        else:
            display_text = f"Ready to package {len(self.input_paths)} root item(s):\n\n"
            for path in self.input_paths:
                display_text += f"- {os.path.basename(path)}\n"
        self.text_input.insert("1.0", display_text)
        self.update_ui_for_mode()
        self.text_input.config(state="disabled")

    def update_ui_for_mode(self):
        if self.mode_var.get() == "Decrypt":
            self.text_input.config(bg="#e0e8f0")
        else:
            self.text_input.config(bg="white")

    def clear_fields(self):
        self.input_paths.clear()
        self.password_entry.delete(0, tk.END)
        self.mode_var.set("Encrypt")
        self.update_display_text()
        self.progress_bar['value'] = 0
        self.progress_label.config(text="Status: Ready")
        self._update_password_strength()

    def process(self):
        password = self.password_entry.get()
        if not self.input_paths:
            messagebox.showwarning("Input Required", "Please drop one or more files/folders first.")
            return
        if len(password) < 8:
            messagebox.showerror("Invalid Password", "Password must be at least 8 characters long.")
            return
        
        self.process_button.config(state="disabled", text="Processing...")
        self.progress_bar['value'] = 0
        self.progress_label.config(text="Starting...")
        mode = self.mode_var.get()
        level = self.security_level.get()
        
        if mode == "Decrypt":
            output_dir_parent = filedialog.askdirectory(title="Select Folder to Save Decrypted Files", initialdir=os.path.expanduser('~'))
            if not output_dir_parent:
                self.process_button.config(state="normal", text="Process")
                return
            archive_name = os.path.basename(self.input_paths[0]).replace('.grn', '')
            output_directory = os.path.join(output_dir_parent, f"decrypted_{archive_name}")
            args = (mode, password, self.input_paths, level, output_directory)
        else:
            args = (mode, password, self.input_paths, level, None)
        
        thread = threading.Thread(target=self._process_threaded, args=args, daemon=True)
        thread.start()

    def _process_threaded(self, mode: str, password: str, paths: List[str], level: str, output_directory: Optional[str]):
        try:
            if mode == "Encrypt":
                generator = self.crypto_service.encrypt_paths(password, paths, level)
            else:
                generator = self.crypto_service.decrypt_archive(password, paths[0], output_directory, level)

            while True:
                try:
                    processed, total = next(generator)
                    self.progress_queue.put((processed, total))
                except StopIteration as e:
                    result_path = e.value
                    break
            
            self.progress_queue.put(f"Process complete! Output saved to {result_path}")
            self.root.after(0, lambda: messagebox.showinfo("Success", f"Process complete!\nOutput saved to:\n{result_path}"))
            self.root.after(0, self.clear_fields)

        except (InvalidTag, argon2.exceptions.VerifyMismatchError):
            self.root.after(0, lambda: messagebox.showerror("Error", "Decryption failed. Invalid password or package manipulation caught."))
        except PermissionError as pe:
            self.root.after(0, lambda: messagebox.showerror("Security Threat Exception", str(pe)))
        except Exception as e:
            self.root.after(0, lambda: messagebox.showerror("Error", f"An unexpected processing error occurred: {e}"))
        finally:
            self.root.after(0, lambda: self.process_button.config(state="normal", text="Process"))
            self.root.after(0, lambda: self.progress_label.config(text="Status: Done"))

