class EncryptionApp:
    def __init__(self, root: TkinterDnD.Tk):
        self.root = root
        self.crypto_service = CryptoService()
        self.root.title("Python Griffin Grinder 1.15.0 - Hardened FAT Architecture")
        self.root.geometry("550x550")
        self.root.minsize(500, 500)
        self.root.configure(bg="#f0f0f0")
        self.input_paths: List[str] = []
        self.progress_queue = queue.Queue()
        self.main_frame = tk.Frame(root, bg="#f0f0f0", padx=20, pady=20)
        self.main_frame.pack(expand=True, fill="both")
        
        tk.Label(self.main_frame, text="Password:", bg="#f0f0f0", font=("Helvetica", 10, "bold")).pack(anchor="w")
