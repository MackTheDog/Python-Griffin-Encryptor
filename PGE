        self.password_entry.pack(fill="x", pady=(0, 5))
        self.password_entry.bind("<KeyRelease>", self._update_password_strength)
        
        strength_frame = tk.Frame(self.main_frame, bg="#f0f0f0")
        strength_frame.pack(fill="x", pady=(0, 10))
        self.strength_bar = ttk.Progressbar(strength_frame, orient="horizontal", length=100, mode="determinate")
