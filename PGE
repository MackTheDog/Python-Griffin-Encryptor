        timestamp = datetime.now().strftime("%Y-%m-%d_%H%M%S")
        output_filename = f"secure_package_{timestamp}.grn.txt"
        final_output_path = os.path.join(desktop_path, output_filename)
        temp_binary_path = final_output_path + ".tmp"
        
        file_list = list(self._get_all_filepaths(input_paths))
        
        total_unencrypted_size = sum(os.path.getsize(fp) for fp, _ in file_list)
        msg_bytes = None
        if embedded_msg:
            msg_bytes = embedded_msg.encode('utf-8')
            total_unencrypted_size += len(msg_bytes)
            
        processed_size = 0
        salt = os.urandom(self.SALT_BYTES)
        master_key = self.generate_master_key(password, salt, level)
        
        try:
            fat_entries = []
            current_payload_offset = 0
            
            for full_path, relative_path in file_list:
                real_size = os.path.getsize(full_path)
                PADDING_BLOCK_SIZE = 16 * 1024
                remainder = real_size % PADDING_BLOCK_SIZE
                padding_needed = PADDING_BLOCK_SIZE - remainder if remainder != 0 else 0
                padded_plaintext_size = real_size + padding_needed
                
                num_chunks = (padded_plaintext_size + self.CHUNK_SIZE - 1) // self.CHUNK_SIZE
                total_encrypted_entry_size = num_chunks * (self.NONCE_BYTES + 4 + 16) + padded_plaintext_size

                fat_entries.append({
                    'filename': relative_path,
                    'real_size': real_size,
                    'padded_plaintext_size': padded_plaintext_size,
                    'relative_payload_offset': current_payload_offset,
                    'is_virtual': False
                })
                current_payload_offset += total_encrypted_entry_size

            if msg_bytes:
                real_size = len(msg_bytes)
                PADDING_BLOCK_SIZE = 16 * 1024
                remainder = real_size % PADDING_BLOCK_SIZE
                padding_needed = PADDING_BLOCK_SIZE - remainder if remainder != 0 else 0
                padded_plaintext_size = real_size + padding_needed
                
                num_chunks = (padded_plaintext_size + self.CHUNK_SIZE - 1) // self.CHUNK_SIZE
                total_encrypted_entry_size = num_chunks * (self.NONCE_BYTES + 4 + 16) + padded_plaintext_size
                
                fat_entries.append({
                    'filename': 'README.txt',
                    'real_size': real_size,
                    'padded_plaintext_size': padded_plaintext_size,
                    'relative_payload_offset': current_payload_offset,
                    'is_virtual': True
                })

            fat_bytes = json.dumps(fat_entries).encode('utf-8')
            fat_key = self.derive_ephemeral_key(master_key, "fat_header_encryption")
            
            aesgcm_fat = AESGCM(bytes(fat_key))
            fat_nonce = os.urandom(self.NONCE_BYTES)
            encrypted_fat = aesgcm_fat.encrypt(fat_nonce, fat_bytes, None)
            self._zero_bytearray(fat_key)

            with open(temp_binary_path, 'wb') as f_out:
                f_out.write(salt)
                f_out.write(fat_nonce)
                f_out.write(len(encrypted_fat).to_bytes(4, 'big'))
                f_out.write(encrypted_fat)
                
                for index, entry in enumerate(fat_entries):
                    yield processed_size, total_unencrypted_size
                    file_key = self.derive_ephemeral_key(master_key, f"file_payload_{index}")
                    
                    if not entry['is_virtual']:
                        full_path, _ = file_list[index]
                        for chunk_processed in self._write_encrypted_payload(f_out, file_key, full_path, entry):
                            yield processed_size + chunk_processed, total_unencrypted_size
                    else:
                        for chunk_processed in self._write_virtual_payload(f_out, file_key, msg_bytes, entry):
                            yield processed_size + chunk_processed, total_unencrypted_size
                        
                    processed_size += entry['real_size']
                    self._zero_bytearray(file_key)
            
            yield total_unencrypted_size, total_unencrypted_size
            with open(temp_binary_path, 'rb') as bin_f, open(final_output_path, 'wb') as armor_f:
                base64.encode(bin_f, armor_f)
                
            if os.path.exists(temp_binary_path):
                os.remove(temp_binary_path)

            if shred_source:
                for full_path, _ in file_list:
                    self.secure_shred_file(full_path)
                    
            return final_output_path
            
        finally:
            self._zero_bytearray(master_key)

    def _write_encrypted_payload(self, f_out, key: bytearray, full_path: str, fat_entry: dict) -> Generator[int, None, None]:
        aesgcm = AESGCM(bytes(key))
        real_size = fat_entry['real_size']
        padded_size = fat_entry['padded_plaintext_size']
        processed_real_bytes = 0
        total_plaintext_streamed = 0
        seed_padding = os.urandom(65536)
        
        with open(full_path, 'rb') as f_in:
            while total_plaintext_streamed < padded_size:
                bytes_to_read = min(self.CHUNK_SIZE, padded_size - total_plaintext_streamed)
                chunk = f_in.read(bytes_to_read) if processed_real_bytes < real_size else b''
                actual_read_len = len(chunk)
                processed_real_bytes += actual_read_len
                
                if actual_read_len < bytes_to_read:
                    needed_padding = bytes_to_read - actual_read_len
                    padding_block = (seed_padding * ((needed_padding // len(seed_padding)) + 1))[:needed_padding]
                    chunk += padding_block
                
                total_plaintext_streamed += len(chunk)
                content_nonce = os.urandom(self.NONCE_BYTES)
                encrypted_content = aesgcm.encrypt(content_nonce, chunk, None)
                
                f_out.write(content_nonce)
                f_out.write(len(encrypted_content).to_bytes(4, 'big'))
                f_out.write(encrypted_content)
                yield min(processed_real_bytes, real_size)

    def _write_virtual_payload(self, f_out, key: bytearray, data_bytes: bytes, fat_entry: dict) -> Generator[int, None, None]:
        aesgcm = AESGCM(bytes(key))
        padded_size = fat_entry['padded_plaintext_size']
        seed_padding = os.urandom(65536)
        
        chunk = data_bytes
        if len(chunk) < padded_size:
            needed_padding = padded_size - len(chunk)
            padding_block = (seed_padding * ((needed_padding // len(seed_padding)) + 1))[:needed_padding]
            chunk += padding_block
            
        content_nonce = os.urandom(self.NONCE_BYTES)
        encrypted_content = aesgcm.encrypt(content_nonce, chunk, None)
        
        f_out.write(content_nonce)
        f_out.write(len(encrypted_content).to_bytes(4, 'big'))
        f_out.write(encrypted_content)
        yield fat_entry['real_size']

    def decrypt_archive(self, password: str, input_path: str, output_directory: str, level: str) -> Generator[Tuple[int, int], None, str]:
        temp_binary_decode = output_directory + ".bin_tmp"
        working_archive_path = input_path
        
        try:
            with open(input_path, 'r', errors='ignore') as source_f:
                header_check = source_f.read(200).strip()
                
            is_armored = all(c in "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/=\r\n " for c in header_check)
            
            if is_armored:
                with open(input_path, 'rb') as source_b, open(temp_binary_decode, 'wb') as dest_bin_f:
                    base64.decode(source_b, dest_bin_f)
                working_archive_path = temp_binary_decode
        except Exception:
            working_archive_path = input_path

        total_archive_size = os.path.getsize(working_archive_path)
        processed_size = 0
        
        try:
            with open(working_archive_path, 'rb') as f_in:
                salt = f_in.read(self.SALT_BYTES)
                processed_size += self.SALT_BYTES
                yield processed_size, total_archive_size
                
                master_key = self.generate_master_key(password, salt, level)
                try:
                    fat_nonce = f_in.read(self.NONCE_BYTES)
                    fat_len_bytes = f_in.read(4)
                    if len(fat_nonce) < self.NONCE_BYTES or len(fat_len_bytes) < 4:
                        raise ValueError("Malformed archive metadata payload mapping.")
                        
                    fat_len = int.from_bytes(fat_len_bytes, 'big')
                    encrypted_fat = f_in.read(fat_len)
                    if len(encrypted_fat) < fat_len:
                        raise ValueError("Package Corruption detected.")
                    
                    fat_key = self.derive_ephemeral_key(master_key, "fat_header_encryption")
                    aesgcm_fat = AESGCM(bytes(fat_key))
                    
                    fat_json = aesgcm_fat.decrypt(fat_nonce, encrypted_fat, None)
                    fat_entries = json.loads(fat_json)
                    self._zero_bytearray(fat_key)
                    
                    processed_size += self.NONCE_BYTES + 4 + fat_len
                    yield processed_size, total_archive_size
                    
                    absolute_payload_base_offset = f_in.tell()

                    for index, entry in enumerate(fat_entries):
                        relative_filename = entry['filename']
                        real_size = entry['real_size']
                        padded_plaintext_size = entry['padded_plaintext_size']
                        rel_offset = entry['relative_payload_offset']
                        
                        clean_rel_path = relative_filename.replace("/", os.sep)
                        output_filepath = os.path.normpath(os.path.join(output_directory, clean_rel_path))
                        base_target_path = os.path.abspath(output_directory)
                        
                        if not os.path.abspath(output_filepath).startswith(base_target_path):
                            raise PermissionError(f"Directory traversal compromise caught: {relative_filename}")
                            
                        if os.path.exists(output_filepath):
                            dir_part = os.path.dirname(output_filepath)
                            name_part, extension_part = os.path.splitext(os.path.basename(output_filepath))
                            counter = 1
                            while os.path.exists(output_filepath):
                                unique_name = f"{name_part} ({counter}){extension_part}"
                                output_filepath = os.path.join(dir_part, unique_name)
                                counter += 1

                        os.makedirs(os.path.dirname(output_filepath), exist_ok=True)
                        f_in.seek(absolute_payload_base_offset + rel_offset)
                        
                        file_key = self.derive_ephemeral_key(master_key, f"file_payload_{index}")
                        aesgcm = AESGCM(bytes(file_key))
                        
                        bytes_written, total_decrypted = 0, 0
                        with open(output_filepath, 'wb') as f_out:
                            while total_decrypted < padded_plaintext_size:
                                content_nonce = f_in.read(self.NONCE_BYTES)
                                content_len_bytes = f_in.read(4)
                                if len(content_nonce) < self.NONCE_BYTES or len(content_len_bytes) < 4:
                                    raise ValueError("Parsing failure: Payload stream disconnected.")
                                    
                                content_len = int.from_bytes(content_len_bytes, 'big')
                                encrypted_content = f_in.read(content_len)
                                if len(encrypted_content) < content_len:
                                    raise ValueError("Parsing failure: Validation fail.")
                                    
                                decrypted_chunk = aesgcm.decrypt(content_nonce, encrypted_content, None)
                                total_decrypted += len(decrypted_chunk)
                                
                                processed_size += self.NONCE_BYTES + 4 + content_len
                                yield processed_size, total_archive_size
                                
                                if bytes_written < real_size:
                                    bytes_to_write = real_size - bytes_written
                                    data_to_write = decrypted_chunk[:bytes_to_write]
                                    f_out.write(data_to_write)
                                    bytes_written += len(data_to_write)
                                    
                        self._zero_bytearray(file_key)
                finally:
                    self._zero_bytearray(master_key)
        except Exception as e:
            if os.path.exists(temp_binary_decode):
                os.remove(temp_binary_decode)
            raise e
        finally:
            if os.path.exists(temp_binary_decode):
                os.remove(temp_binary_decode)
                
        return output_directory

    @staticmethod
    def _get_all_filepaths(paths: List[str]) -> Generator[Tuple[str, str], None, None]:
        for path in paths:
            if os.path.isfile(path):
                yield path, os.path.basename(path)
            elif os.path.isdir(path):
                root_dir = os.path.dirname(path)
                for base_dir, _, filenames in os.walk(path):
                    for filename in filenames:
                        full_path = os.path.join(base_dir, filename)
                        relative_path = os.path.relpath(full_path, root_dir)
                        unified_path = relative_path.replace(os.sep, "/")
                        yield full_path, unified_path


