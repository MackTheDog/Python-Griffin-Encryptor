    def handle_mode_switch(self, selected_mode: str, force_clear: bool = True):
        if force_clear:
            self.input_paths.clear()
            self.password_entry.delete(0, 'end')
            self.confirm_entry.delete(0, 'end')
        
        self.current_layout_mode = selected_mode
        self.mode_var.set(selected_mode)

        if selected_mode == "Decrypt":
            self.confirm_entry.pack_forget()
            self.process_button.configure(text="Unlock & Extract", fg_color="#2980b9", hover_color="#3498db")
        else:
            self.confirm_entry.pack(after=self.password_entry, fill="x", pady=5)
            self.process_button.configure(text="Lock Package", fg_color="#2ecc71", hover_color="#27ae60")
            
        self.update_display_text()
        self._validate_passwords()

    def _validate_passwords(self, event=None) -> bool:
        mode = self.mode_var.get()
        p1 = self.password_entry.get()
        p2 = self.confirm_entry.get()
        
        if len(p1) < 8:
            self.status_feedback_label.configure(text="⚠️ Minimum safety threshold: 8 characters required.", text_color="#ff4d4d")
            self.process_button.configure(state="disabled")
            return False
            
        if mode == "Encrypt":
            if p1 != p2:
                self.status_feedback_label.configure(text="❌ Entry Error: Master passwords do not match.", text_color="#ff4d4d")
                self.process_button.configure(state="disabled")
                return False
            else:
                self.status_feedback_label.configure(text="✨ Verification success: Passwords match.", text_color="#2ecc71")
                self.process_button.configure(state="normal")
                return True
        else:
            self.status_feedback_label.configure(text="🔒 Ready to decode matching archive context.", text_color="#3498db")
            self.process_button.configure(state="normal")
            return True

    def handle_drop(self, event):
        try:
            raw_dropped_items = self.root.tk.splitlist(event.data)
            dropped_items = []
            
            for path in raw_dropped_items:
                path = path.strip()
                if path.startswith("file://"):
                    path = urllib.parse.unquote(path[7:])
                if os.path.exists(path):
                    dropped_items.append(path)

            if not dropped_items:
                return
                
            is_package_file = len(dropped_items) == 1 and dropped_items[0].endswith('.grn')
            
            if is_package_file:
                self.input_paths = dropped_items
                self.handle_mode_switch("Decrypt", force_clear=False)
            else:
                for p in dropped_items:
                    if p not in self.input_paths and not p.endswith('.grn'):
                        self.input_paths.append(p)
                self.handle_mode_switch("Encrypt", force_clear=False)
                
            self.update_display_text()
            self._validate_passwords()
        except Exception as e:
            messagebox.showerror("Drop Processing Defect", f"Could not map targeted filesystem layout: {e}")
            self.clear_fields()

    def update_display_text(self):
        self.drop_zone.configure(state="normal")
        self.drop_zone.delete("1.0", "end")
        
        if not self.input_paths:
            display_text = "\n\n\n\t\t📥 LANDING PAD INFRASTRUCTURE\n\n\t\tDrag and drop folders or files here..."
        elif self.mode_var.get() == "Decrypt":
            display_text = f"\n📦 TARGET ARMORED PACKAGE DETECTED:\n\n- {os.path.basename(self.input_paths[0])}"
        else:
            display_text = f"📂 PENDING STRUCTURAL ROOT ALLOCATIONS ({len(self.input_paths)} items):\n\n"
            for p in self.input_paths:
                display_text += f"- {os.path.basename(p)}\n"
                
        self.drop_zone.insert("1.0", display_text)
        self.drop_zone.configure(state="disabled")

    def clear_fields(self):
        self.input_paths.clear()
        self.password_entry.delete(0, 'end')
        self.confirm_entry.delete(0, 'end')
        self.handle_mode_switch("Encrypt", force_clear=True)
        self.progress_bar.set(0)
        self.progress_label.configure(text="Status: Cleaned Session.")
        self._validate_passwords()

    def check_queue(self):
        try:
            while True:
                message = self.progress_queue.get_nowait()
                if isinstance(message, tuple):
                    processed, total = message
                    ratio = (processed / total) if total > 0 else 0
                    self.progress_bar.set(ratio)
                    self.progress_label.configure(text=f"Processing Payload Stream... {int(ratio * 100)}%")
                elif isinstance(message, str):
                    self.progress_label.configure(text=message)
        except queue.Empty:
            pass
        finally:
            self.root.after(100, self.check_queue)

    def process(self):
        if not self._validate_passwords():
            return
            
        password = self.password_entry.get()
        mode = self.mode_var.get()
        level = self.security_level.get()
        
        self.process_button.configure(state="disabled", text="Computing KDF...")
        self.progress_bar.set(0)
        
        if mode == "Decrypt":
            output_dir_parent = filedialog.askdirectory(title="Select Destination Extract Root", initialdir=os.path.expanduser('~'))
            if not output_dir_parent:
                self.handle_mode_switch(mode, force_clear=False)
                return
            archive_name = os.path.basename(self.input_paths[0]).replace('.grn', '')
            output_directory = os.path.join(output_dir_parent, f"decrypted_{archive_name}")
            args = (mode, password, self.input_paths, level, output_directory)
        else:
            args = (mode, password, self.input_paths, level, None)
            
        thread = threading.Thread(target=self._process_threaded, args=args, daemon=True)
        thread.start()

    def _process_threaded(self, mode: str, password: str, paths: List[str], level: str, output_directory: Optional[str]):
        try:
            if mode == "Encrypt":
                generator = self.crypto_service.encrypt_paths(password, paths, level)
            else:
                generator = self.crypto_service.decrypt_archive(password, paths[0], output_directory, level)

            while True:
                try:
                    processed, total = next(generator)
                    self.progress_queue.put((processed, total))
                except StopIteration as e:
                    result_path = e.value
                    break
                    
            self.progress_queue.put(f"Success! Destination mapped to {os.path.basename(result_path)}")
            self.root.after(0, lambda: messagebox.showinfo("Process Complete", f"Operation executed successfully!\nSaved to:\n{result_path}"))
            self.root.after(0, self.clear_fields)
        except (InvalidTag, argon2.exceptions.VerifyMismatchError):
            self.root.after(0, lambda: messagebox.showerror("Cryptographic Rejection", "Operation Failed. Struct authenticity validation failed or incorrect master password sequence."))
        except PermissionError as pe:
            self.root.after(0, lambda: messagebox.showerror("Security Boundary Warning", str(pe)))
        except Exception as e:
            self.root.after(0, lambda: messagebox.showerror("Fatal Pipeline Defect", f"An internal failure occurred during stream processing: {e}"))
        finally:
            self.root.after(0, lambda: self.handle_mode_switch(self.mode_var.get(), force_clear=False))

