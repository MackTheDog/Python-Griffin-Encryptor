# -----------------------------------------------------------------------------
# -- CRYPTO SERVICE CLASS WITH ENCRYPTED FAT HEADER & MEMORY HARDENING
# -----------------------------------------------------------------------------
class CryptoService:
    CHUNK_SIZE = 16 * 1024 * 1024
    KEY_BYTES = 32
    SALT_BYTES = 32
    NONCE_BYTES = 12
    HEADER_VERSION = b'\x09'  # Upgraded version for the FAT layout
    MIN_PADDED_PLAINTEXT_SIZE = 5 * 1024 * 1024

    def _zero_bytearray(self, b: bytearray) -> None:
        """Securely overwrites sensitive RAM blocks with zeroes."""
        if b:
            for i in range(len(b)):
                b[i] = 0

    def generate_master_key(self, password_str: str, salt: bytes, level: str) -> bytearray:
        if level == "Strong":
            time_cost, memory_cost, parallelism = 16, 1048576, 4
        elif level == "Fast":
            time_cost, memory_cost, parallelism = 2, 102400, 2
        else: # Normal
            time_cost, memory_cost, parallelism = 7, 524288, 2
            
        raw_pwd = password_str.encode('utf-8')
        try:
            raw_key = argon2.low_level.hash_secret_raw(
                secret=raw_pwd, salt=salt, time_cost=time_cost,
                memory_cost=memory_cost, parallelism=parallelism,
                hash_len=self.KEY_BYTES, type=argon2.low_level.Type.ID
            )
            return bytearray(raw_key)
        finally:
            # Wipe plain-text password from raw encoder bytes out of RAM instantly
            if isinstance(raw_pwd, bytearray):
                self._zero_bytearray(raw_pwd)

    def derive_ephemeral_key(self, master_key: bytearray, info_str: str) -> bytearray:
        """Derives an isolated key for individual structures (FAT vs Chunks)."""
        hkdf = HKDF(
            algorithm=hashes.SHA256(),
            length=self.KEY_BYTES,
            salt=None,
            info=info_str.encode('utf-8')
        )
        derived = hkdf.derive(bytes(master_key))
        return bytearray(derived)

    def encrypt_paths(self, password: str, input_paths: List[str], level: str) -> Generator[Tuple[int, int], None, str]:
        desktop_path = os.path.join(os.path.expanduser('~'), 'Desktop')
        timestamp = datetime.now().strftime("%Y-%m-%d_%H%M%S")
        output_filename = f"encrypted_package_{timestamp}.grn"
        final_output_path = os.path.join(desktop_path, output_filename)
        
        file_list = list(self._get_all_filepaths(input_paths))
        total_unencrypted_size = sum(os.path.getsize(fp) for fp, _ in file_list)
        processed_size = 0

        salt = os.urandom(self.SALT_BYTES)
        master_key = self.generate_master_key(password, salt, level)
        
        try:
            # 1. Build Pre-FAT Architecture Map to calculate precise layout offsets
            fat_entries = []
            current_payload_offset = 0 # Relative offset starting right after the FAT block
            
            for full_path, relative_path in file_list:
                real_size = os.path.getsize(full_path)
                padded_plaintext_size = max(real_size, self.MIN_PADDED_PLAINTEXT_SIZE)
                
                # AESGCM tag adds overhead per chunk. Calculate how many chunks this payload will make
                num_chunks = (padded_plaintext_size + self.CHUNK_SIZE - 1) // self.CHUNK_SIZE
                # Format size per chunk: NONCE_BYTES (12) + LENGTH_FIELD (4) + CHUNK_DATA + AESGCM_TAG (16)
                total_encrypted_entry_size = num_chunks * (self.NONCE_BYTES + 4 + self.CHUNK_SIZE + 16)
                # Remainder chunk sizing adjustment
                remainder = padded_plaintext_size % self.CHUNK_SIZE
                if remainder != 0:
                    total_encrypted_entry_size -= (self.CHUNK_SIZE - remainder)

                fat_entries.append({
                    'filename': relative_path,
                    'real_size': real_size,
                    'padded_plaintext_size': padded_plaintext_size,
                    'relative_payload_offset': current_payload_offset
                })
                current_payload_offset += total_encrypted_entry_size

            # 2. Encrypt the FAT Header Block
            fat_bytes = json.dumps(fat_entries).encode('utf-8')
            fat_key = self.derive_ephemeral_key(master_key, "fat_header_encryption")
            
            aesgcm_fat = AESGCM(bytes(fat_key))
            fat_nonce = os.urandom(self.NONCE_BYTES)
            encrypted_fat = aesgcm_fat.encrypt(fat_nonce, fat_bytes, None)
            
            self._zero_bytearray(fat_key) # Hardening wipe

            # 3. Write Core Structures out to Storage
            with open(final_output_path, 'wb') as f_out:
                f_out.write(self.HEADER_VERSION + salt)
                f_out.write(fat_nonce)
                f_out.write(len(encrypted_fat).to_bytes(4, 'big'))
                f_out.write(encrypted_fat)
                
                # 4. Stream File Payloads and Padding Layers Sequentially
                for index, (full_path, _) in enumerate(file_list):
                    yield processed_size, total_unencrypted_size
                    
                    file_key = self.derive_ephemeral_key(master_key, f"file_payload_{index}")
                    
                    for chunk_processed in self._write_encrypted_payload(f_out, file_key, full_path, fat_entries[index]):
                        yield processed_size + chunk_processed, total_unencrypted_size
                        
                    processed_size += fat_entries[index]['real_size']
                    self._zero_bytearray(file_key) # Hardening wipe
                    
            yield total_unencrypted_size, total_unencrypted_size
            return final_output_path
            
        finally:
            self._zero_bytearray(master_key) # Complete core key scrub from memory

    def _write_encrypted_payload(self, f_out, key: bytearray, full_path: str, fat_entry: dict) -> Generator[int, None, None]:
        aesgcm = AESGCM(bytes(key))
        real_size = fat_entry['real_size']
        padding_size = fat_entry['padded_plaintext_size'] - real_size
        
        processed_in_file = 0
        with open(full_path, 'rb') as f_in:
            while chunk := f_in.read(self.CHUNK_SIZE):
                content_nonce = os.urandom(self.NONCE_BYTES)
                encrypted_content = aesgcm.encrypt(content_nonce, chunk, None)
                f_out.write(content_nonce)
                f_out.write(len(encrypted_content).to_bytes(4, 'big'))
                f_out.write(encrypted_content)
                processed_in_file += len(chunk)
                yield processed_in_file

        remaining_padding = padding_size
        while remaining_padding > 0:
            chunk_size = min(remaining_padding, self.CHUNK_SIZE)
            padding_chunk = os.urandom(chunk_size)
            content_nonce = os.urandom(self.NONCE_BYTES)
            encrypted_content = aesgcm.encrypt(content_nonce, padding_chunk, None)
            f_out.write(content_nonce)
            f_out.write(len(encrypted_content).to_bytes(4, 'big'))
            f_out.write(encrypted_content)
            remaining_padding -= chunk_size

    def decrypt_archive(self, password: str, input_path: str, output_directory: str, level: str) -> Generator[Tuple[int, int], None, str]:
        total_archive_size = os.path.getsize(input_path)
        processed_size = 0
        
        with open(input_path, 'rb') as f_in:
            version = f_in.read(1)
            if version != self.HEADER_VERSION:
                raise ValueError("Format mismatch! This file layout requires the V9 FAT Architecture Engine.")
                
            salt = f_in.read(self.SALT_BYTES)
            processed_size += 1 + self.SALT_BYTES
            yield processed_size, total_archive_size
            
            master_key = self.generate_master_key(password, salt, level)
            
            try:
                # 1. Extract and Parse the Unified Encrypted FAT Header Block
                fat_nonce = f_in.read(self.NONCE_BYTES)
                fat_len_bytes = f_in.read(4)
                if len(fat_nonce) < self.NONCE_BYTES or len(fat_len_bytes) < 4:
                    raise ValueError("Malformed file structure: Missing Allocation boundaries.")
                    
                fat_len = int.from_bytes(fat_len_bytes, 'big')
                encrypted_fat = f_in.read(fat_len)
                if len(encrypted_fat) < fat_len:
                    raise ValueError("Package Corruption: Unified Header Table cut short.")
                
                fat_key = self.derive_ephemeral_key(master_key, "fat_header_encryption")
                aesgcm_fat = AESGCM(bytes(fat_key))
                
                fat_json = aesgcm_fat.decrypt(fat_nonce, encrypted_fat, None)
                fat_entries = json.loads(fat_json)
                
                self._zero_bytearray(fat_key) # Hardening wipe
                
                processed_size += self.NONCE_BYTES + 4 + fat_len
                yield processed_size, total_archive_size
                
                # Record the absolute boundary location where the payload sequence begins inside the file
                absolute_payload_base_offset = f_in.tell()

                # 2. Iterate and Extract file targets using f_in.seek dynamic jumps
                for index, entry in enumerate(fat_entries):
                    relative_filename = entry['filename']
                    real_size = entry['real_size']
                    padded_plaintext_size = entry['padded_plaintext_size']
                    rel_offset = entry['relative_payload_offset']
                    
                    # Target Path Traversal remediation block
                    output_filepath = os.path.join(output_directory, relative_filename)
                    resolved_path = os.path.abspath(output_filepath)
                    base_target_path = os.path.abspath(output_directory)
                    if not resolved_path.startswith(base_target_path):
                        raise PermissionError(f"Directory traversal compromise caught: {relative_filename}")
                        
                    os.makedirs(os.path.dirname(output_filepath), exist_ok=True)
                    
                    # CRITICAL OPTIMIZATION: Instant dynamic file pointer jump via FAT parameters
                    f_in.seek(absolute_payload_base_offset + rel_offset)
                    
                    file_key = self.derive_ephemeral_key(master_key, f"file_payload_{index}")
                    aesgcm = AESGCM(bytes(file_key))
                    
                    bytes_written, total_decrypted = 0, 0
                    with open(output_filepath, 'wb') as f_out:
                        while total_decrypted < padded_plaintext_size:
                            content_nonce = f_in.read(self.NONCE_BYTES)
                            content_len_bytes = f_in.read(4)
                            if len(content_nonce) < self.NONCE_BYTES or len(content_len_bytes) < 4:
                                raise ValueError("Parsing failure: Payload stream disconnected unexpectedly.")
                                
                            content_len = int.from_bytes(content_len_bytes, 'big')
                            encrypted_content = f_in.read(content_len)
                            if len(encrypted_content) < content_len:
                                raise ValueError("Parsing failure: Block segment validation failed.")
                                
                            decrypted_chunk = aesgcm.decrypt(content_nonce, encrypted_content, None)
                            total_decrypted += len(decrypted_chunk)
                            
                            # Fake out parsing updates globally via relative processing progress markers
                            processed_size += self.NONCE_BYTES + 4 + content_len
                            yield processed_size, total_archive_size
                            
                            if bytes_written < real_size:
                                bytes_to_write = real_size - bytes_written
                                data_to_write = decrypted_chunk[:bytes_to_write]
                                f_out.write(data_to_write)
                                bytes_written += len(data_to_write)
                                
                    self._zero_bytearray(file_key) # Hardening wipe
                    
            finally:
                self._zero_bytearray(master_key) # Complete core key scrub from memory
                
        return output_directory

    @staticmethod
    def _get_all_filepaths(paths: List[str]) -> Generator[Tuple[str, str], None, None]:
        for path in paths:
            if os.path.isfile(path):
                yield path, os.path.basename(path)
            elif os.path.isdir(path):
                base_dir = os.path.dirname(path)
                for root, _, files in os.walk(path):
                    for name in files:
                        full_path = os.path.join(root, name)
                        relative_path = os.path.relpath(full_path, base_dir)
                        yield full_path, relative_path

